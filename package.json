{
  "name": "create-soybean",
  "version": "1.6.1",
  "description": "The official scaffolding tool by SoybeanJS for quickly creating different project templates.",
  "homepage": "https://github.com/soybeanjs/create-soybean",
  "bugs": {
    "url": "https://github.com/soybeanjs/create-soybean/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Soybean",
    "email": "soybeanjs@outlook.com",
    "url": "https://github.com/soybeanjs"
  },
  "repository": {
    "url": "https://github.com/soybeanjs/create-soybean.git"
  },
  "bin": {
    "create-soybean": "./src/bin.js"
  },
  "files": [
    "dist",
    "template-*"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "bin": {
      "create-soybean": "dist/index.js"
    },
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "cleanup": "soy cleanup",
    "commit": "soy git-commit",
    "lint": "oxlint --fix && oxfmt",
    "fmt": "oxfmt",
    "prepare": "simple-git-hooks",
    "publish-pkg": "pnpm publish --access public",
    "release": "soy release -e 'pnpm release-execute'",
    "release-execute": "tsx ./scripts/release.ts && pnpm soy changelog",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "upkg": "soy ncu",
    "rei": "pnpm cleanup && pnpm i"
  },
  "dependencies": {
    "consola": "^3.4.2",
    "kolorist": "^1.8.0",
    "minimist": "^1.2.8",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@soybeanjs/cli": "^1.6.2",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm soy git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint-staged"
  },
  "lint-staged": {
    "*": "oxlint --fix && oxfmt"
  },
  "packageManager": "pnpm@10.32.1"
}
