{
  "name": "template-vue-tsdown",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "cleanup": "soy cleanup",
    "commit": "soy git-commit",
    "dev": "tsdown --watch",
    "lint": "oxlint --fix",
    "fmt": "oxfmt",
    "play": "vite",
    "prepare": "simple-git-hooks",
    "publish-pkg": "pnpm publish --access public",
    "release": "soy release",
    "test": "vitest",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "upkg": "soy update-pkg"
  },
  "dependencies": {
    "consola": "catalog:prod"
  },
  "devDependencies": {
    "@soybeanjs/cli": "catalog:dev",
    "@types/node": "catalog:dev",
    "@vue/test-utils": "catalog:dev",
    "happy-dom": "catalog:dev",
    "lint-staged": "catalog:dev",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "tsdown": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "unplugin-vue": "catalog:dev",
    "unplugin-vue-jsx": "catalog:dev",
    "vite": "catalog:dev",
    "vue": "catalog:dev",
    "vue-tsc": "catalog:dev"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm soy git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint-staged"
  },
  "lint-staged": {
    "*": "oxlint --fix && oxfmt"
  },
  "packageManager": "pnpm@10.32.1"
}
