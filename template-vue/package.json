{
  "name": "template-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cleanup": "soy cleanup",
    "commit": "soy git-commit",
    "dev": "vite",
    "lint": "oxlint --fix",
    "fmt": "oxfmt",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "upkg": "soy ncu"
  },
  "dependencies": {
    "@soybeanjs/ui": "^0.12.4",
    "@unocss/reset": "^66.6.7",
    "klona": "^2.0.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@soybeanjs/cli": "^1.7.1",
    "@soybeanjs/unocss-preset": "^0.2.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "elegant-router": "^1.3.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.7",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.1",
    "vue-tsc": "^3.2.6"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm soy git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint-staged"
  },
  "lint-staged": {
    "*": "oxlint --fix && oxfmt"
  },
  "packageManager": "pnpm@10.32.1"
}
